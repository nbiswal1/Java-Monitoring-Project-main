pipeline {
    agent any
    
    tools {
        jdk 'Java 17'
        maven 'Maven-3.9'
    }

    stages {
        stage('Verify Tools') {
            steps {
                sh 'java -version'
                sh 'mvn -version'
            }
        }

        stage('Git Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/jaiswaladi246/Boardgame.git'
            }
        }

        stage('Build Project') {
            steps {
                sh 'mvn clean package'
            }
        }
    }
}
